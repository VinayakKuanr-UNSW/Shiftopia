# Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================

# Supabase project URL - Get from Supabase Dashboard > Settings > API
# Example: https://yourproject.supabase.co
VITE_SUPABASE_URL=

# Supabase anonymous/public key - Get from Supabase Dashboard > Settings > API
# This is safe to expose in the frontend bundle
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# BUILD CONFIGURATION (Optional)
# =============================================================================

# Set to 'development' or 'production'
# Default: development
NODE_ENV=development

# =============================================================================
# ML / SHIFT SYNTHESISER SERVICE (Optional — required for labour forecasting)
# =============================================================================

# Base URL of the FastAPI ML service (POST /predict/demand)
# Default: http://localhost:8000 when running via docker-compose
VITE_ML_URL=http://localhost:8000

# =============================================================================
# SENTRY (Optional — error monitoring)
# =============================================================================

# Public DSN — safe to expose in the bundle. Errors are reported only when set.
# Get from Sentry Dashboard > Project Settings > Client Keys (DSN).
VITE_SENTRY_DSN=

# Environment label shown on each event ("production", "staging", etc.).
# Falls back to Vite's MODE if unset.
VITE_SENTRY_ENVIRONMENT=

# Release identifier — typically the git SHA. Set in CI.
VITE_SENTRY_RELEASE=

# Sampling rates (0.0 – 1.0). Defaults: traces=0.1, replay=0, replay-on-error=1.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Build-time source-map upload (CI only — never commit these).
# Without these vars, the build still succeeds; uploads are skipped.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# NOTES
# =============================================================================
# - Never commit .env with real values to version control
# - The Supabase Service Role Key should NEVER be used in the frontend
# - Edge functions use SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY from Supabase's
#   built-in environment (automatically injected, do not set manually)
